generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./election.db"
}

model Candidate {
  id         Int    @id @default(autoincrement())
  name       String
  class_name String
  gender     String // "Male" or "Female"
  image_path String // e.g., "/uploads/alice.jpg"
}

model EncryptedVote {
  id                      Int      @id @default(autoincrement())
  class_name              String
  encrypted_ballot_string String   // Stored as "IV : Ciphertext : AuthTag"
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  action     String
  details    String?
  created_at DateTime @default(now())
}
